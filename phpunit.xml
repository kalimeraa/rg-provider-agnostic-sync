<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="vendor/autoload.php"
         colors="true"
>
    <testsuites>
        <testsuite name="Unit">
            <directory>tests/Unit</directory>
        </testsuite>
        <testsuite name="Feature">
            <directory>tests/Feature</directory>
        </testsuite>
    </testsuites>
    <source>
        <include>
            <directory>app</directory>
        </include>
    </source>
    <php>
        <!-- force="true" ZORUNLU: docker container'ında bu değişkenlerin hepsi
             zaten .env üzerinden GERÇEK process env var'ı olarak set edilmiş
             (docker-compose.yml'in env_file: .env'i). force olmadan PHPUnit,
             "zaten set edilmiş" bir env var'ı SESSİZCE ez­mez — bu yüzden bu
             satırlar force'suz hiçbir işe yaramıyordu (testler farkında
             olmadan gerçek `db`'ye karşı, redis queue ile çalışıyordu).
             Canlı doğrulandı: force eklenmeden önce config('queue.default')
             testler içinde "redis" dönüyordu, APP_ENV "local" kalıyordu. -->
        <env name="APP_ENV" value="testing" force="true"/>
        <env name="BCRYPT_ROUNDS" value="4" force="true"/>
        <env name="CACHE_DRIVER" value="array" force="true"/>
        <!-- ShouldBroadcastNow event'leri (SyncStatusUpdated, FailedJobRecorded) gerçek
             Reverb'e HTTP çağrısı yapmaya çalışmasın diye — testler Reverb'siz çalışır. -->
        <env name="BROADCAST_DRIVER" value="log" force="true"/>
        <!-- SQLite DEĞİL: db_test, docker-compose.yml'deki ayrı bir MySQL container'ı (üretimle aynı motor). -->
        <env name="DB_CONNECTION" value="mysql" force="true"/>
        <env name="DB_HOST" value="db_test" force="true"/>
        <env name="DB_PORT" value="3306" force="true"/>
        <env name="DB_DATABASE" value="product_sync_test" force="true"/>
        <env name="DB_USERNAME" value="product_sync" force="true"/>
        <env name="DB_PASSWORD" value="secret" force="true"/>
        <env name="MAIL_MAILER" value="array" force="true"/>
        <env name="PULSE_ENABLED" value="false" force="true"/>
        <env name="QUEUE_CONNECTION" value="sync" force="true"/>
        <env name="SESSION_DRIVER" value="array" force="true"/>
        <env name="TELESCOPE_ENABLED" value="false" force="true"/>
    </php>
</phpunit>
