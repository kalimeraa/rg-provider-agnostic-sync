<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="vendor/autoload.php"
         colors="true"
>
    <testsuites>
        <testsuite name="Unit">
            <directory>tests/Unit</directory>
        </testsuite>
        <testsuite name="Feature">
            <directory>tests/Feature</directory>
        </testsuite>
    </testsuites>
    <source>
        <include>
            <directory>app</directory>
        </include>
        <!-- Bu projenin domain'ine (product sync) ait olmayan, `laravel new`
             tarafından üretilmiş ve HİÇ özelleştirilmemiş iskelet dosyaları —
             sıfır custom mantık içerdikleri için (sadece parent class'tan
             property override eden boş kabuklar) coverage'a dahil etmek
             gerçek bir sinyal üretmez, sadece gürültü olur. `App\Models\User`
             ve Sanctum, projede hiçbir yerde gerçekten kullanılmıyor (case'in
             API'si tamamen açık, token üretimi/tüketimi yok). -->
        <exclude>
            <file>app/Http/Kernel.php</file>
            <directory>app/Http/Middleware</directory>
            <file>app/Models/User.php</file>
        </exclude>
    </source>
    <php>
        <!-- Laravel 10.x testing dokümantasyonu: `APP_ENV=testing` set
             edilince Laravel, `.env` yerine kök dizindeki `.env.testing`'i
             okur (DB_HOST=db_test, QUEUE_CONNECTION=sync vb. hepsi orada) —
             bkz. https://laravel.com/docs/10.x/testing#the-env-testing-environment-file.
             Bunun çalışabilmesi için docker-compose.yml'de `server`/`worker`/
             `reverb` servislerinde BİLEREK `env_file: .env` YOK (bkz. o
             dosyadaki açıklama) — aksi halde container'ın OS ortamı
             `.env.testing`'in üzerini sessizce ezerdi. -->
        <env name="APP_ENV" value="testing"/>
    </php>
</phpunit>
