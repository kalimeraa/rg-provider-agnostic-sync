APP_NAME="Product Sync"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080
# docker-compose kullanılırken nginx'in (webserver servisi) host'ta bağlandığı port
APP_PORT=8080

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Artisan'ı host'ta çalıştırırken "127.0.0.1", container içindeyken "db"/"redis"
# (docker-compose servis adları) kullan.
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=product_sync
DB_USERNAME=product_sync
DB_PASSWORD=secret

# Ayrı bir MySQL container'ı (docker-compose: db_test, host port 3307) — testler
# SQLite değil bunun üzerinden çalışır (bkz. phpunit.xml). `db`'den bağımsız,
# testler prod verisine hiç dokunmaz.
DB_TEST_DATABASE=product_sync_test

BROADCAST_DRIVER=reverb
# Redis cache zorunlu: SyncProviderJob'ın ShouldBeUnique kilidi, server/worker
# container'ları arasında paylaşılan atomik bir cache lock'a ihtiyaç duyar
# (worker = Horizon + scheduler, aynı container'da supervisord altında) —
# file/array driver'lar bunu sağlayamaz.
CACHE_DRIVER=redis
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
# database: `sessions` migration'ı zaten iskelette var (2026_07_03_121007_create_sessions_table.php).
SESSION_DRIVER=database
SESSION_LIFETIME=120

# "predis" (pure-PHP client) — bilerek phpredis C-extension'ı DEĞİL, image'i
# yalın tutmak için (bkz. CLAUDE.md). Bu satır olmadan Laravel varsayılan
# olarak "phpredis"e düşer ve kurulu olmadığı için "Class Redis not found" hatası verir.
REDIS_CLIENT=predis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ---------------------------------------------------------------------------
# Ürün senkronizasyon ayarları (bkz. config/sync.php)
# ---------------------------------------------------------------------------

# Tedarikçi API'lerinin base URL'leri
SYNC_DUMMYJSON_BASE_URL=https://dummyjson.com
SYNC_FAKESTORE_BASE_URL=https://fakestoreapi.com

# Scheduler'ın her provider için sync job'ını ne sıklıkta tetiklediği (dakika, case spec'ine göre 5-10)
SYNC_INTERVAL_MINUTES=5

# Tek bir tedarikçi API'sine saniyede gönderilecek maksimum istek sayısı
SYNC_RATE_LIMIT_PER_SECOND=5

# Bu kadar ardışık başarısız HTTP isteğinden sonra sync'i durdur (ve alert üret)
SYNC_MAX_CONSECUTIVE_FAILURES=5

# Bir provider'ın unique sync-job kilidinin en fazla tutulacağı süre (saniye) —
# worker, kilidi bırakmadan ölürse diye kendiliğinden iyileşme tavanı
SYNC_JOB_UNIQUE_FOR=900

# ---------------------------------------------------------------------------
# Alerting (bkz. app/Services/Alerts/AlertService.php)
# ---------------------------------------------------------------------------

# Structured JSON alert logları her zaman storage/logs/alerts.log'a yazılır.
# Ayrıca bir Slack incoming-webhook bildirimi de göndermek için bunu ayarla;
# bildirimleri kapatıp sadece log dosyasına güvenmek için boş bırak.
ALERT_SLACK_WEBHOOK_URL=

ALERT_CONSECUTIVE_SYNC_FAILURES=3
ALERT_FAILED_JOB_THRESHOLD=10
ALERT_CONSECUTIVE_API_FAILURES=5
ALERT_QUEUE_BACKLOG_THRESHOLD=100
# Aynı tür iki alert arasındaki minimum dakika
ALERT_THROTTLE_MINUTES=5

# ---------------------------------------------------------------------------
# Real-time dashboard updates (Laravel Reverb — WebSocket broadcasting)
# ---------------------------------------------------------------------------
# Reverb, docker-compose'daki ayrı bir "reverb" container'ında çalışır ve
# nginx (docker/nginx/conf.d/default.conf) tarafından /app/ altında proxy'lenir
# — böylece dashboard'daki JS istemcisi sadece tek bir host/port'a (nginx'in
# baktığı APP_PORT) bağlanır, ayrı bir port açmaya gerek kalmaz. Şimdilik SSL
# ile uğraşılmıyor: sadece düz http/ws, "localhost" ile çalışacak şekilde.
REVERB_APP_ID=product-sync
REVERB_APP_KEY=product-sync-key
REVERB_APP_SECRET=product-sync-secret

# PHP tarafının (server/worker container'ları) event yayınlamak için Reverb'e
# yaptığı server-to-server çağrılar için — docker network'teki servis adı.
REVERB_HOST=reverb
REVERB_PORT=8080
REVERB_SCHEME=http

# Reverb sunucusunun kendi container'ı içinde dinlediği adres/port.
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080
