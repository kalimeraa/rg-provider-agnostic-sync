APP_NAME="Product Sync"
APP_ENV=testing
APP_KEY=base64:hv5Pkx8b5V/1gbqD7iez+F811NiDNHZ/VVdHgELvjDg=
APP_DEBUG=true

LOG_CHANNEL=stack
LOG_LEVEL=debug

# db_test — docker-compose.yml'deki ayrı bir MySQL container'ı (host port
# 3307), `db`'den (üretim/dev verisi) tamamen izole. Testler buna karşı
# çalışır ki motor-spesifik davranış farkları (ör. decimal yuvarlama,
# timestamp hassasiyeti) production'da yakalanmadan test aşamasında
# yakalansın.
DB_CONNECTION=mysql
DB_HOST=db_test
DB_PORT=3306
DB_DATABASE=product_sync_test
DB_USERNAME=product_sync
DB_PASSWORD=secret

BROADCAST_DRIVER=log
CACHE_DRIVER=array
QUEUE_CONNECTION=sync
SESSION_DRIVER=array
MAIL_MAILER=array

BCRYPT_ROUNDS=4
PULSE_ENABLED=false
TELESCOPE_ENABLED=false

# HealthController Redis'e cache driver'dan bağımsız doğrudan bağlanıp ping
# atıyor — CACHE_DRIVER=array olsa da bu değişkenler gerçek `redis`
# container'ını göstermeli, aksi halde REDIS_HOST varsayılanı (127.0.0.1)
# container ağında karşılık bulamaz. Ayrı bir redis_test CONTAINER'I YOK
# (db_test'in aksine) — Redis'in kendi mantıksal DB indexleri (0-15) tam
# olarak bu izolasyon için var; dev zaten 0 (default) ve 1'i (cache)
# kullanıyor, testler farklı indexlere (5/6) yazarak aynı sunucuyu paylaşsa
# bile veriler asla karışmaz. Ayrı bir container, burada gerçek kullanım
# (CACHE_DRIVER=array + QUEUE_CONNECTION=sync yüzünden testlerin Redis'e
# dokunduğu tek yer bu health-check ping'i) göz önüne alınınca gereksiz
# altyapı olurdu.
REDIS_CLIENT=predis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=5
REDIS_CACHE_DB=6
